# ---- Kafka / Redpanda ----
KAFKA_BROKERS=localhost:19092

# ---- Simulator ----
# Deterministic seed for reproducible runs
SIM_SEED=42
# Initial scenario: bull | crash | sideways | volatility | whale | open
SIM_SCENARIO=sideways
# Tick interval in milliseconds
SIM_TICK_MS=250

# ---- Gateway ----
# kafka  -> consume aggregated state from Redpanda
# standalone -> run the market engine in-process (no Kafka required)
GATEWAY_MODE=standalone
GATEWAY_WS_PORT=4001
METRICS_PORT=9101

# ---- Aggregator ----
AGG_METRICS_PORT=9102

# ---- Web ----
NEXT_PUBLIC_GATEWAY_WS_URL=ws://localhost:4001/stream
